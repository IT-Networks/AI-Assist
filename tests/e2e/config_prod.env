# E2E Test Configuration for Production
# Copy to .env or source before running tests

# AI-Assist Production Server
AI_ASSIST_URL=http://localhost:8000

# LLM Backend (leave empty to skip proxy health check)
# For real LLM: leave PROXY_URL empty
# For test proxy: PROXY_URL=http://localhost:8080
PROXY_URL=

# Model to use for testing
# Production: gpt-4o-mini, gpt-4o, claude-3-opus, etc.
# Test Proxy: gptoss120b (mapped to gpt-4o-mini)
TEST_MODEL=gpt-4o-mini

# Test Settings
TEST_TIMEOUT=180
TEST_WORKSPACE=C:/Users/marku/OneDrive/Dokumente/VisualCode/AI-Assist/e2e-test-workspace

# Retry Settings (for flaky tests)
TEST_RETRIES=2
TEST_RETRY_DELAY=5
