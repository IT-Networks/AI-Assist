# LLM Backend
LLM_BASE_URL=http://internal-llm-gateway/v1
LLM_API_KEY=your-api-key-here

# Java Repository
JAVA_REPO_PATH=/home/user/projects/my-java-app

# Confluence
CONFLUENCE_BASE_URL=https://confluence.example.com
CONFLUENCE_USERNAME=user@company.com
CONFLUENCE_API_TOKEN=your-atlassian-api-token   # Cloud: API-Token
CONFLUENCE_PASSWORD=your-password               # Server/DC: Passwort (statt API-Token)
